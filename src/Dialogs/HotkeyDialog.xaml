<Window x:Class="KeystrokeCommander.Dialogs.HotkeyDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Capture Hotkey" Height="160" Width="380"
        Background="#181A20" Foreground="#E2E4E9"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize">
  <Window.Resources>
    <Style TargetType="Button">
      <Setter Property="Background" Value="#23262E" />
      <Setter Property="Foreground" Value="#E2E4E9" />
      <Setter Property="BorderBrush" Value="#333842" />
      <Setter Property="Padding" Value="14 6" />
      <Setter Property="FontSize" Value="13" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="Button">
            <Border Background="{TemplateBinding Background}"
                    BorderBrush="{TemplateBinding BorderBrush}"
                    BorderThickness="{TemplateBinding BorderThickness}"
                    CornerRadius="4">
              <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
            </Border>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
      <Style.Triggers>
        <Trigger Property="IsMouseOver" Value="True">
          <Setter Property="Background" Value="#2A2E38" />
        </Trigger>
      </Style.Triggers>
    </Style>
  </Window.Resources>

  <Grid Margin="16">
    <StackPanel>
      <TextBlock Text="Press the key combination you want to assign:"
                 FontSize="13" Foreground="#8B90A0" Margin="0 0 0 12" />
      <Border Background="#13151A" BorderBrush="#333842"
              BorderThickness="1" CornerRadius="4"
              Padding="10 8" Margin="0 0 0 16">
        <TextBlock x:Name="HotkeyText" Text="(press keys...)"
                   FontFamily="Consolas" FontSize="16"
                   Foreground="#E2E4E9" HorizontalAlignment="Center" />
      </Border>
      <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
        <Button Content="Cancel" IsCancel="True" Margin="0 0 8 0"
                Click="Cancel_Click" />
        <Button Content="OK" IsDefault="True" Click="Ok_Click" />
      </StackPanel>
    </StackPanel>
  </Grid>
</Window>
