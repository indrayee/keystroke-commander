<Window x:Class="KeystrokeCommander.HotkeyDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Assign Hotkey" Height="580" Width="800"
        Background="#14161C" Foreground="#E2E4E9"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize" Topmost="True"
        PreviewKeyDown="Window_PreviewKeyDown"
        PreviewKeyUp="Window_PreviewKeyUp">
  <Grid Margin="40">
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto" />
      <RowDefinition Height="Auto" />
      <RowDefinition Height="Auto" />
      <RowDefinition Height="Auto" />
    </Grid.RowDefinitions>

    <TextBlock Grid.Row="0" Text="Press your desired hotkey:" FontSize="20"
              FontWeight="SemiBold" Foreground="#E2E4E9" Margin="0 0 0 24" />

    <Border Grid.Row="1" Background="#13151A" BorderBrush="#339AF0" BorderThickness="2"
            CornerRadius="8" Padding="28 32" Margin="0 0 0 36">
      <TextBlock x:Name="ComboText" Text="(press keys...)" FontSize="48"
                FontWeight="Bold" Foreground="#339AF0" HorizontalAlignment="Center"
                FontFamily="Consolas" />
    </Border>

    <TextBlock Grid.Row="2" Text="Example: Shift + Alt + S, Ctrl + F1"
              FontSize="14" Foreground="#6B7080" HorizontalAlignment="Center"
              Margin="0 0 0 36" />

    <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Center">
      <Button x:Name="AssignBtn" Content="Assign" Padding="40 16" Margin="0 0 16 0"
              Background="#51CF66" Foreground="#000000" BorderThickness="0"
              FontSize="17" FontWeight="SemiBold" Click="AssignBtn_Click"
              IsEnabled="False" />
      <Button Content="Cancel" Padding="40 16"
              Background="#23262E" Foreground="#8B90A0" BorderBrush="#333842" BorderThickness="1"
              FontSize="17" FontWeight="SemiBold" Click="CancelBtn_Click" />
    </StackPanel>
  </Grid>
</Window>
