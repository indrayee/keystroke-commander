<Window x:Class="KeystrokeCommander.HotkeyDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Assign Hotkey" Height="200" Width="420"
        Background="#14161C" Foreground="#E2E4E9"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize" Topmost="True"
        KeyDown="Window_KeyDown" PreviewKeyDown="Window_PreviewKeyDown"
        KeyUp="Window_KeyUp">
  <Grid Margin="20 24">
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto" />
      <RowDefinition Height="Auto" />
      <RowDefinition Height="Auto" />
    </Grid.RowDefinitions>

    <TextBlock Grid.Row="0" Text="Press your desired key combination:" FontSize="13"
              Foreground="#8B90A0" Margin="0 0 0 12" />

    <Border Grid.Row="1" Background="#13151A" BorderBrush="#339AF0" BorderThickness="1"
            CornerRadius="4" Padding="12 14" Margin="0 0 0 20">
      <TextBlock x:Name="ComboText" Text="(press keys...)" FontSize="18"
                FontWeight="SemiBold" Foreground="#339AF0" HorizontalAlignment="Center" />
    </Border>

    <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Center">
      <Button x:Name="AssignBtn" Content="Assign" Padding="16 6" Margin="0 0 8 0"
              Background="#339AF0" Foreground="#FFFFFF" BorderThickness="0"
              FontSize="13" Click="AssignBtn_Click" IsEnabled="False" />
      <Button Content="Cancel" Padding="16 6"
              Background="#13151A" Foreground="#8B90A0" BorderBrush="#333842" BorderThickness="1"
              FontSize="13" Click="CancelBtn_Click" />
    </StackPanel>
  </Grid>
</Window>
