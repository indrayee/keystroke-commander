<Window x:Class="KeystrokeCommander.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="clr-namespace:KeystrokeCommander.ViewModels"
        mc:Ignorable="d"
        Title="Keystroke Commander" Height="700" Width="1050"
        Background="#14161C" Foreground="#E2E4E9"
        WindowStartupLocation="CenterScreen"
        FontFamily="Segoe UI"
        Topmost="{Binding AlwaysOnTop}">
  <Window.DataContext>
    <vm:MainViewModel />
  </Window.DataContext>
  <Window.Resources>
    <SolidColorBrush x:Key="BgDark" Color="#181A20" />
    <SolidColorBrush x:Key="BgMedium" Color="#1E2128" />
    <SolidColorBrush x:Key="BorderColor" Color="#2A2D35" />
    <SolidColorBrush x:Key="TextMuted" Color="#8B90A0" />
    <SolidColorBrush x:Key="AccentBlue" Color="#339AF0" />
    <SolidColorBrush x:Key="AccentGreen" Color="#51CF66" />
    <SolidColorBrush x:Key="AccentRed" Color="#FF6B6B" />

    <Style x:Key="DarkButton" TargetType="Button">
      <Setter Property="Background" Value="#23262E" />
      <Setter Property="Foreground" Value="#E2E4E9" />
      <Setter Property="BorderBrush" Value="#333842" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="Padding" Value="8 5" />
      <Setter Property="FontSize" Value="13" />
      <Setter Property="Cursor" Value="Hand" />
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="Button">
            <Border Background="{TemplateBinding Background}"
                    BorderBrush="{TemplateBinding BorderBrush}"
                    BorderThickness="{TemplateBinding BorderThickness}"
                    CornerRadius="4">
              <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
            </Border>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
      <Style.Triggers>
        <Trigger Property="IsMouseOver" Value="True">
          <Setter Property="Background" Value="#2A2E38" />
        </Trigger>
      </Style.Triggers>
    </Style>

    <Style x:Key="GreenButton" TargetType="Button" BasedOn="{StaticResource DarkButton}">
      <Setter Property="BorderBrush" Value="#2D6A4F" />
      <Setter Property="Foreground" Value="#69DB7C" />
    </Style>

    <Style x:Key="RedButton" TargetType="Button" BasedOn="{StaticResource DarkButton}">
      <Setter Property="BorderBrush" Value="#8B1E1E" />
      <Setter Property="Foreground" Value="#FF6B6B" />
    </Style>

    <Style x:Key="SmallButton" TargetType="Button" BasedOn="{StaticResource DarkButton}">
      <Setter Property="Padding" Value="6 4" />
      <Setter Property="FontSize" Value="11" />
    </Style>

    <Style x:Key="DangerButton" TargetType="Button" BasedOn="{StaticResource SmallButton}">
      <Setter Property="BorderBrush" Value="#5C1E1E" />
      <Setter Property="Foreground" Value="#FF6B6B" />
    </Style>

    <Style TargetType="TextBox">
      <Setter Property="Background" Value="#13151A" />
      <Setter Property="Foreground" Value="#E2E4E9" />
      <Setter Property="BorderBrush" Value="#333842" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="Padding" Value="6 5" />
      <Setter Property="FontSize" Value="13" />
    </Style>

    <Style TargetType="ComboBox">
      <Setter Property="Background" Value="#FFFFFF" />
      <Setter Property="Foreground" Value="#000000" />
      <Setter Property="BorderBrush" Value="#CCCCCC" />
      <Setter Property="Padding" Value="6 5" />
      <Setter Property="FontSize" Value="13" />
      <Setter Property="ItemContainerStyle">
        <Setter.Value>
          <Style TargetType="ComboBoxItem">
            <Setter Property="Background" Value="#FFFFFF" />
            <Setter Property="Foreground" Value="#000000" />
            <Setter Property="Padding" Value="8 6" />
            <Style.Triggers>
              <Trigger Property="IsSelected" Value="True">
                <Setter Property="Background" Value="#339AF0" />
                <Setter Property="Foreground" Value="#FFFFFF" />
              </Trigger>
              <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="Background" Value="#E8F0FE" />
              </Trigger>
            </Style.Triggers>
          </Style>
        </Setter.Value>
      </Setter>
    </Style>

    <Style x:Key="HotkeyBadge" TargetType="Border">
      <Setter Property="Background" Value="#23262E" />
      <Setter Property="BorderBrush" Value="#333842" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="CornerRadius" Value="3" />
      <Setter Property="Padding" Value="4 2" />
    </Style>

    <Style TargetType="CheckBox">
      <Setter Property="Foreground" Value="#8B90A0" />
    </Style>

    <Style TargetType="DataGrid">
      <Setter Property="Background" Value="#14161C" />
      <Setter Property="Foreground" Value="#E2E4E9" />
      <Setter Property="BorderBrush" Value="#2A2D35" />
      <Setter Property="RowBackground" Value="#14161C" />
      <Setter Property="AlternatingRowBackground" Value="#181A20" />
      <Setter Property="GridLinesVisibility" Value="Horizontal" />
      <Setter Property="HorizontalGridLinesBrush" Value="#22252D" />
      <Setter Property="HeadersVisibility" Value="Column" />
      <Setter Property="CanUserAddRows" Value="False" />
      <Setter Property="CanUserDeleteRows" Value="False" />
      <Setter Property="AutoGenerateColumns" Value="False" />
      <Setter Property="CellStyle">
        <Setter.Value>
          <Style TargetType="DataGridCell">
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="8 6" />
            <Setter Property="Foreground" Value="#E2E4E9" />
            <Style.Triggers>
              <Trigger Property="IsSelected" Value="True">
                <Setter Property="Background" Value="#1A2F4A" />
                <Setter Property="Foreground" Value="#FFFFFF" />
              </Trigger>
            </Style.Triggers>
          </Style>
        </Setter.Value>
      </Setter>
      <Setter Property="ColumnHeaderStyle">
        <Setter.Value>
          <Style TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="#1E2128" />
            <Setter Property="Foreground" Value="#C9CCD6" />
            <Setter Property="BorderBrush" Value="#2A2D35" />
            <Setter Property="BorderThickness" Value="0 0 0 1" />
            <Setter Property="Padding" Value="8 6" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="FontSize" Value="12" />
          </Style>
        </Setter.Value>
      </Setter>
      <Setter Property="RowStyle">
        <Setter.Value>
          <Style TargetType="DataGridRow">
            <Setter Property="Foreground" Value="#E2E4E9" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="MinHeight" Value="28" />
          </Style>
        </Setter.Value>
      </Setter>
    </Style>
  </Window.Resources>

  <Grid>
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto" />
      <RowDefinition Height="*" />
    </Grid.RowDefinitions>

    <!-- ========== TOP BAR ========== -->
    <Border Grid.Row="0" Background="{StaticResource BgMedium}" BorderBrush="{StaticResource BorderColor}" BorderThickness="0 0 0 1">
      <StackPanel Orientation="Horizontal" Margin="12 10">
        <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="0 0 16 0">
          <TextBlock Text="TARGET WINDOW" FontSize="11" Foreground="{StaticResource TextMuted}"
                    VerticalAlignment="Center" Margin="0 0 8 0" />
          <ComboBox x:Name="WindowPicker" Width="340" VerticalAlignment="Center"
                    ItemsSource="{Binding VisibleWindows}"
                    SelectedItem="{Binding SelectedWindow}"
                    ToolTip="Select target window — will receive all keystrokes"
                    DropDownOpened="WindowPicker_DropDownOpened"
                    DropDownClosed="WindowPicker_DropDownClosed">
            <ComboBox.ItemTemplate>
              <DataTemplate>
                <TextBlock>
                  <TextBlock.Text>
                    <MultiBinding StringFormat="{}{0} — &quot;{1}&quot; ({2}x{3})">
                      <Binding Path="ProcessName" />
                      <Binding Path="Title" />
                      <Binding Path="Width" />
                      <Binding Path="Height" />
                    </MultiBinding>
                  </TextBlock.Text>
                </TextBlock>
              </DataTemplate>
            </ComboBox.ItemTemplate>
          </ComboBox>
          <Button Style="{StaticResource SmallButton}" Margin="6 0 0 0"
                  Content="⟳" FontSize="16" Padding="4 0"
                  ToolTip="Refresh window list"
                  Command="{Binding RefreshWindowsCommand}" />
        </StackPanel>

        <Button Style="{StaticResource GreenButton}" Margin="8 0"
                Command="{Binding LockWindowCommand}">
          <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
            <Ellipse Width="10" Height="10" Fill="{Binding LockDotColor}"
                      Margin="0 0 6 0" VerticalAlignment="Center" />
            <TextBlock Text="{Binding LockButtonText}" />
          </StackPanel>
        </Button>

        <Button Style="{StaticResource RedButton}" Margin="8 0"
                Command="{Binding StopAllCommand}">
          <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
            <Ellipse Width="10" Height="10" Fill="#FF6B6B"
                      Margin="0 0 6 0" VerticalAlignment="Center" />
            <TextBlock Text="Stop All" />
          </StackPanel>
        </Button>

        <CheckBox Content="Always on Top" VerticalAlignment="Center"
                  Margin="16 0 0 0" IsChecked="{Binding AlwaysOnTop}" />
      </StackPanel>
    </Border>

    <!-- ========== BODY ========== -->
    <Grid Grid.Row="1">
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="260" />
        <ColumnDefinition Width="*" />
      </Grid.ColumnDefinitions>

      <!-- === LEFT PANEL: Profile List === -->
      <Border Grid.Column="0" Background="{StaticResource BgDark}" BorderBrush="{StaticResource BorderColor}" BorderThickness="0 0 1 0">
        <DockPanel>
          <!-- Header -->
          <Border DockPanel.Dock="Top" BorderBrush="{StaticResource BorderColor}" BorderThickness="0 0 0 1">
            <DockPanel Margin="12 10">
              <TextBlock DockPanel.Dock="Left" Text="PROFILES" FontSize="12" FontWeight="SemiBold"
                        Foreground="{StaticResource TextMuted}" VerticalAlignment="Center" />
              <TextBlock DockPanel.Dock="Right" Text="{Binding ProfileCountText}" FontSize="11"
                        Foreground="#6B7080" HorizontalAlignment="Right" />
            </DockPanel>
          </Border>

          <!-- Global Stop (docked bottom) -->
          <Border DockPanel.Dock="Bottom" Background="#2A1515"
                 BorderBrush="#5C1E1E" BorderThickness="1"
                 CornerRadius="4" Margin="10 8">
            <Grid Margin="8">
              <TextBlock Text="🛑 Global Stop" FontSize="12"
                        Foreground="#FF6B6B" VerticalAlignment="Center" />
              <Border HorizontalAlignment="Right" Background="#3A1A1A"
                       BorderBrush="#5C1E1E" BorderThickness="1"
                       CornerRadius="3" Padding="4 2">
                <TextBlock Text="{Binding GlobalStopHotkey}"
                          FontFamily="Consolas" FontSize="11"
                          Foreground="#FF6B6B" />
              </Border>
            </Grid>
          </Border>

          <!-- New Profile (docked bottom) -->
          <Border DockPanel.Dock="Bottom" Margin="10 0 10 8"
                 BorderBrush="#555" BorderThickness="1"
                 CornerRadius="4">
            <Button Content="+ New Profile" Background="Transparent"
                    BorderThickness="0" Foreground="#8B90A0"
                    FontSize="12" Padding="8"
                    Command="{Binding NewProfileCommand}" />
          </Border>

          <!-- Profile List -->
          <ScrollViewer VerticalScrollBarVisibility="Auto">
            <ListBox ItemsSource="{Binding Profiles}" SelectedItem="{Binding SelectedProfile}"
                     Background="Transparent" BorderThickness="0"
                     ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                     AlternationCount="2">
              <ListBox.ItemContainerStyle>
                <Style TargetType="ListBoxItem">
                  <Setter Property="Padding" Value="0" />
                  <Setter Property="Background" Value="Transparent" />
                  <Setter Property="Foreground" Value="Transparent" />
                  <Setter Property="BorderThickness" Value="0" />
                  <Setter Property="Template">
                    <Setter.Value>
                      <ControlTemplate TargetType="ListBoxItem">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                BorderBrush="#22252D" BorderThickness="0 0 0 1"
                                Padding="10 12" Cursor="Hand">
                          <ContentPresenter />
                        </Border>
                        <ControlTemplate.Triggers>
                          <Trigger Property="IsSelected" Value="True">
                            <Setter TargetName="Bd" Property="Background" Value="#1A2F4A" />
                            <Setter TargetName="Bd" Property="BorderBrush" Value="#339AF0" />
                          </Trigger>
                          <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Bd" Property="Background" Value="#1A1D24" />
                          </Trigger>
                        </ControlTemplate.Triggers>
                      </ControlTemplate>
                    </Setter.Value>
                  </Setter>
                </Style>
              </ListBox.ItemContainerStyle>
              <ListBox.ItemTemplate>
                <DataTemplate>
                  <Grid>
                    <Grid.ColumnDefinitions>
                      <ColumnDefinition Width="*" />
                      <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.Column="0" Text="{Binding Name}" FontSize="13"
                              Foreground="#E2E4E9" VerticalAlignment="Center"
                              Margin="0 0 8 0" />

                    <Border Grid.Column="1" Style="{StaticResource HotkeyBadge}">
                      <TextBlock Text="{Binding HotkeyDisplay}"
                                FontSize="11" Foreground="#8B90A0" />
                    </Border>
                  </Grid>
                </DataTemplate>
              </ListBox.ItemTemplate>
            </ListBox>
          </ScrollViewer>
        </DockPanel>
      </Border>

      <!-- === RIGHT PANEL: Editor === -->
      <Grid Grid.Column="1" Background="#14161C">
        <Grid.RowDefinitions>
          <RowDefinition Height="Auto" />
          <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Profile Meta Header -->
        <Border Grid.Row="0" BorderBrush="{StaticResource BorderColor}" BorderThickness="0 0 0 1">
          <StackPanel Orientation="Horizontal" Margin="16 12">
            <TextBox Text="{Binding SelectedProfile.Name, UpdateSourceTrigger=PropertyChanged}"
                      Width="200" Margin="0 0 16 0" />

            <Border Background="#13151A" BorderBrush="{StaticResource BorderColor}"
                    BorderThickness="1" CornerRadius="4">
              <StackPanel Orientation="Horizontal">
                <Button Content="Sequential"
                        Background="{Binding SeqButtonBg}"
                        Foreground="{Binding SeqButtonFg}"
                        BorderThickness="0" Padding="10 6"
                        FontSize="12"
                        Command="{Binding SetModeSequentialCommand}" />
                <Button Content="Concurrent"
                        Background="{Binding ConButtonBg}"
                        Foreground="{Binding ConButtonFg}"
                        BorderThickness="0" Padding="10 6"
                        FontSize="12"
                        Command="{Binding SetModeConcurrentCommand}" />
              </StackPanel>
            </Border>

            <StackPanel Orientation="Horizontal" Margin="16 0 0 0" VerticalAlignment="Center">
              <TextBlock Text="Profile Hotkey: " FontSize="12"
                        Foreground="{StaticResource TextMuted}" VerticalAlignment="Center" />
              <Border Style="{StaticResource HotkeyBadge}" Margin="6 0">
                <TextBlock Text="{Binding SelectedProfile.HotkeyDisplay}"
                          FontFamily="Consolas" FontSize="12"
                          Foreground="#E2E4E9" />
              </Border>
              <Button Style="{StaticResource SmallButton}"
                      Content="Change"
                      Command="{Binding ChangeHotkeyCommand}" />
            </StackPanel>
          </StackPanel>
        </Border>

        <!-- Sequence / Repeater Editor -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Margin="16">
          <StackPanel>
            <TextBlock Text="{Binding EditorTitle}"
                      FontSize="11" Foreground="#6B7080"
                      Margin="0 0 0 10" />

            <DataGrid x:Name="EditorGrid"
                      ItemsSource="{Binding EditorItems}"
                      CanUserReorderColumns="False"
                      CanUserResizeColumns="True">
              <DataGrid.Columns>
                <DataGridTextColumn Header="Keystroke"
                                     Binding="{Binding Key}" Width="120" />
                <DataGridTextColumn Header="Delay/Interval (ms)"
                                     Binding="{Binding DelayMs}" Width="130" />
                <DataGridTextColumn Header="Hold (ms)"
                                     Binding="{Binding HoldMs}" Width="90" />
                <DataGridCheckBoxColumn Header="Jitter"
                                        Binding="{Binding Jitter}" Width="70" />
                <DataGridTemplateColumn Width="60">
                  <DataGridTemplateColumn.CellTemplate>
                    <DataTemplate>
                      <Button Style="{StaticResource DangerButton}"
                              Content="✕"
                              Command="{Binding DataContext.DeleteRowCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                              CommandParameter="{Binding}" />
                    </DataTemplate>
                  </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
              </DataGrid.Columns>
            </DataGrid>

            <Border Margin="0 12 0 0" BorderBrush="#555" BorderThickness="1"
                   CornerRadius="4">
              <Button Content="{Binding AddRowText}" Background="Transparent"
                      BorderThickness="0" Foreground="#6B7080"
                      FontSize="12" Padding="8"
                      Command="{Binding AddRowCommand}" />
            </Border>

            <Border Background="#1A2520" BorderBrush="#2D4A35"
                    BorderThickness="1" CornerRadius="4"
                    Margin="0 16 0 0" Padding="10 12">
              <TextBlock Text="{Binding ModeHint}" FontSize="12"
                        Foreground="#69DB7C" TextWrapping="Wrap" />
            </Border>
          </StackPanel>
        </ScrollViewer>
      </Grid>
    </Grid>
  </Grid>
</Window>
